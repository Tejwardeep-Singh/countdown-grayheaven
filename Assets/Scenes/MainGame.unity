--- !u!114 &1038127732
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1038127731}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Here I am\u2026 alone in the quiet of a dead city.\nI\u2019ve spent my
    life building a reputation as a fearless detective \u2014 Tim Crowe.\nTonight,
    that reputation is being tested.\n\nA terrorist has challenged me.\nA bomb is
    hidden somewhere in this city.\nEvacuation was the easy part.\nFinding it\u2026
    won\u2019t be.\n\nNo team. No backup.\nJust me, the city, and time slipping away.\n\nHe
    said the answer is already in front of me.\nEverything begins here.\nThe SNERAW
    Memorial isn\u2019t a tribute \u2014 it\u2019s a message.\n\nDawn is the limit.\nThe
    countdown has begun\u2026"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: db0b52ab8085eaf42bda802b2e84f36f, type: 2}
  m_sharedMaterial: {fileID: -8158239793162755618, guid: db0b52ab8085eaf42bda802b2e84f36f, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
