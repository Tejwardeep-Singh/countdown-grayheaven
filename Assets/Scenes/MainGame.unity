  m_Script: {fileID: 11500000, guid: 85f3d678f85cc5347b35ea9c11bedc71, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroController
  introPanel: {fileID: 653759742}
  blackFade: {fileID: 1485028549}
  pauseButton: {fileID: 1908185192}
  introText: {fileID: 1038127732}
  continueHint: {fileID: 81686319}
  introAudio: {fileID: 548683998}
  playerInteract: {fileID: 1657303346}
  typingSpeed: 0.06
  introMessages:
  - "Here I am\u2026\nAlone in the quiet of a dead city."
  - "I\u2019ve spent my life building a reputation\nas a fearless detective \u2014
    Tim Crowe."
  - 'Tonight,

    that reputation is being tested.'
  - 'A terrorist has challenged me.

    A bomb is hidden somewhere in this city.'
  - "Evacuation was the easy part.\nFinding it\u2026 won\u2019t be."
  - 'No team.

    No backup.'
  - 'Just me, the city,

    and time slipping away.'
  - 'He said the answer

    is already in front of me.'
  - 'Everything begins here.

    The SNERAW Memorial.......'
  - "It isn\u2019t a tribute.\nIt\u2019s a message."
  - Dawn is the limit.
  - "The countdown has begun\u2026"
  tickTockAudio: {fileID: 769960376}
  tickStartIndex: 11
  fadeDuration: 2
  audioFadeDuration: 1.5
