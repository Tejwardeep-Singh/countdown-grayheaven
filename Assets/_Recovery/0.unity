--- !u!114 &1844924058
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1844924057}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The city stands silent.\n\nIts streets evacuated. Its lights abandoned.
    Its people gone. You are Detective Arjun Malik, a senior officer known for solving
    cases no one else could. An hour ago, a terrorist threat was confirmed. A bomb
    has been planted somewhere in the city. The attacker did not run. He did not
    hide. Instead, he issued a challenge. Clues have been scattered across the city
    \u2014 notes, symbols, and messages meant only for you.\nEach one leading closer
    to the truth\u2026\nor further into his game. You have been ordered to enter
    the city alone. No backup. No second chances.\n\nFind the clues.\nLocate the
    bomb.\nDefuse it before time runs out.\n\nThe fate of the city now rests with
